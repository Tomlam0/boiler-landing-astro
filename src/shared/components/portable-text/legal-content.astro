---
import { PortableText } from 'astro-portabletext';
import type { PortableTextBlock } from '@portabletext/types';

import LegalLink from './legal-link.astro';

interface Props {
  value: PortableTextBlock[] | null | undefined;
}

const { value } = Astro.props;
---

{
  value && value.length > 0 && (
    <div
      class="space-y-4 text-base leading-relaxed text-muted-foreground [&_em]:italic [&_h2]:mt-10
        [&_h2]:mb-4 [&_h2]:font-heading [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:text-foreground
        first:[&_h2]:mt-0 [&_h3]:mt-8 [&_h3]:mb-3 [&_h3]:text-xl [&_h3]:font-semibold
        [&_h3]:text-foreground [&_ol]:ml-6 [&_ol]:list-decimal [&_ol]:space-y-2
        [&_ol]:marker:text-primary [&_strong]:font-semibold [&_strong]:text-foreground [&_ul]:ml-6
        [&_ul]:list-disc [&_ul]:space-y-2 [&_ul]:marker:text-primary"
    >
      <PortableText
        value={value}
        components={{
          mark: {
            link: LegalLink,
          },
        }}
      />
    </div>
  )
}
