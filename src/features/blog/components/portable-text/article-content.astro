---
import { PortableText } from 'astro-portabletext';
import type { PortableTextBlock } from '@portabletext/types';

import ArticleImage from './article-image.astro';
import ArticleLink from './article-link.astro';

interface Props {
  value: PortableTextBlock[] | null | undefined;
}

const { value } = Astro.props;
---

{
  value && value.length > 0 ? (
    <div
      class="prose-article space-y-5 text-base leading-relaxed text-foreground/80
        [&_blockquote]:my-8 [&_blockquote]:border-l-2 [&_blockquote]:border-accent
        [&_blockquote]:pl-6 [&_blockquote]:text-foreground/70 [&_blockquote]:italic [&_em]:italic
        [&_h2]:mt-12 [&_h2]:mb-5 [&_h2]:font-heading [&_h2]:text-2xl [&_h2]:font-semibold
        [&_h2]:tracking-tight [&_h2]:text-foreground md:[&_h2]:text-3xl [&_h3]:mt-10 [&_h3]:mb-4
        [&_h3]:font-heading [&_h3]:text-xl [&_h3]:font-semibold [&_h3]:tracking-tight
        [&_h3]:text-foreground [&_ol]:my-5 [&_ol]:list-decimal [&_ol]:pl-6 [&_p]:mb-5
        [&_strong]:font-semibold [&_strong]:text-foreground [&_ul]:my-5 [&_ul]:list-disc
        [&_ul]:pl-6"
    >
      <PortableText
        value={value}
        components={{
          type: {
            image: ArticleImage,
          },
          mark: {
            link: ArticleLink,
          },
        }}
      />
    </div>
  ) : null
}
