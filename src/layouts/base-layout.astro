---
import '@/styles/globals.css';

import Head from '@/shared/components/seo/head.astro';
import { DevAgentationProvider } from '@/shared/components/providers/dev-agentation-provider';
import type { SeoMetadata } from '@/shared/lib/seo/metadata';

interface Props {
  metadata: SeoMetadata;
}

const { metadata } = Astro.props;
---

<html
  lang="fr"
  class="scrollbar scrollbar-thumb-primary scrollbar-thumb-rounded-xs scrollbar-w-3.5
    motion-safe:scroll-smooth scrollbar-hover:scrollbar-thumb-primary/90"
>
  <head>
    <Head metadata={metadata} />
  </head>
  <body class="flex flex-col font-body text-foreground selection:bg-primary selection:text-white">
    <DevAgentationProvider client:idle />
    <slot />
  </body>
</html>
