---
import BaseLayout from '@/layouts/base-layout.astro';
import Nav from '@/shared/components/layout/nav';
import Footer from '@/shared/components/layout/footer';
import SanityVisualEditing from '@/sanity/preview/sanity-visual-editing';
import SanityLive from '@/sanity/preview/sanity-live';
import DisableDraftMode from '@/sanity/preview/disable-draft-mode';
import { addCacheTags } from '@/sanity/content/cache-tags';
import { getSettings } from '@/sanity/content/settings';
import { getDraftModeProps } from '@/sanity/preview/draft-mode';
import type { SeoMetadata } from '@/shared/lib/seo/metadata';

interface BreadcrumbItem {
  name: string;
  url: string;
}

interface Props {
  metadata: SeoMetadata;
  breadcrumbs?: BreadcrumbItem[];
}

const { metadata, breadcrumbs } = Astro.props;
const { perspectiveCookie } = getDraftModeProps(Astro.cookies);
const draftMode = perspectiveCookie !== undefined;

// this layout must be invalidated when settings change.
addCacheTags(Astro.response, 'settings');

const settings = await getSettings();
---

<BaseLayout metadata={metadata} breadcrumbs={breadcrumbs}>
  <Nav client:load />
  <slot />
  <Footer copyright={settings.copyright ?? undefined} social={settings.social} />
  {
    draftMode && (
      <>
        <SanityVisualEditing client:only="react" />
        <SanityLive client:only="react" />
        <DisableDraftMode client:only="react" />
      </>
    )
  }
</BaseLayout>
