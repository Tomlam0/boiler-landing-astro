---
import BaseLayout from '@/layouts/base-layout.astro';
import Nav from '@/shared/components/layout/nav';
import Footer from '@/shared/components/layout/footer';
import { getSettings } from '@/sanity/lib/settings';
import type { SeoMetadata } from '@/shared/lib/seo/metadata';

interface BreadcrumbItem {
  name: string;
  url: string;
}

interface Props {
  metadata: SeoMetadata;
  breadcrumbs?: BreadcrumbItem[];
}

const { metadata, breadcrumbs } = Astro.props;

const settings = await getSettings();
---

<BaseLayout metadata={metadata} breadcrumbs={breadcrumbs}>
  <Nav client:load />
  <slot />
  <Footer copyright={settings.copyright ?? undefined} social={settings.social} />
</BaseLayout>
