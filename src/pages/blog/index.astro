---
import PublicLayout from '@/layouts/public-layout.astro';
import { ArticleList } from '@/features/blog/components/article-list';
import { resolveMetadata } from '@/shared/lib/seo/metadata';
import { env } from '@/shared/lib/env';
import { getDraftModeProps } from '@/sanity/lib/draft-mode';
import { loadQuery } from '@/sanity/lib/load-query';
import { ARTICLES_QUERY } from '@/sanity/schemas/documents/article/article.queries';
import { BLOG_PAGE_QUERY } from '@/sanity/schemas/documents/blog-page/blog-page.queries';
import type {
  ARTICLES_QUERY_RESULT,
  BLOG_PAGE_QUERY_RESULT,
} from '@/sanity/sanity.types';

const { perspectiveCookie } = getDraftModeProps(Astro.cookies);
const [{ data: page }, { data: articles }] = await Promise.all([
  loadQuery<BLOG_PAGE_QUERY_RESULT>({ query: BLOG_PAGE_QUERY, perspectiveCookie }),
  loadQuery<ARTICLES_QUERY_RESULT>({ query: ARTICLES_QUERY, perspectiveCookie }),
]);

const metadata = await resolveMetadata({
  title: page?.seoTitle ?? 'Blog — Projet',
  description:
    page?.seoDescription ??
    'Découvrez nos derniers articles et actualités. Conseils, tutoriels et retours d’expérience.',
  path: 'blog',
  siteName: 'Projet',
});
---

<PublicLayout
  metadata={metadata}
  breadcrumbs={[
    { name: 'Accueil', url: env.SITE_URL },
    { name: 'Blog', url: `${env.SITE_URL}blog` },
  ]}
>
  <main class="flex min-h-screen w-full flex-col select-none">
    <ArticleList articles={articles ?? []} client:visible />
  </main>
</PublicLayout>
