---
import type { PortableTextBlock } from '@portabletext/types';

import PublicLayout from '@/layouts/public-layout.astro';
import ArticleContent from '@/features/blog/components/portable-text/article-content.astro';
import { resolveMetadata } from '@/shared/lib/seo/metadata';
import { env } from '@/shared/lib/env';
import { getDraftModeProps } from '@/sanity/lib/draft-mode';
import { loadQuery } from '@/sanity/lib/load-query';
import { urlFor } from '@/sanity/lib/image';
import { ARTICLE_BY_SLUG_QUERY } from '@/sanity/schemas/documents/article/article.queries';
import type { ARTICLE_BY_SLUG_QUERY_RESULT } from '@/sanity/sanity.types';

const { slug } = Astro.params;

if (!slug) return Astro.redirect('/blog');

const { perspectiveCookie } = getDraftModeProps(Astro.cookies);
const { data: article } = await loadQuery<ARTICLE_BY_SLUG_QUERY_RESULT>({
  query: ARTICLE_BY_SLUG_QUERY,
  params: { slug },
  perspectiveCookie,
});

if (!article) return Astro.redirect('/blog');

const imageUrl = article.image?.asset ? urlFor(article.image).url() : undefined;

const metadata = await resolveMetadata({
  title: article.seoTitle ?? article.title ?? slug,
  description: article.seoDescription ?? article.excerpt ?? '',
  path: `blog/${slug}`,
  ogImage: imageUrl,
  siteName: 'Projet',
});

const publishedAt = article.publishedAt
  ? new Date(article.publishedAt).toLocaleDateString('fr-FR', {
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    })
  : null;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BlogPosting',
      '@id': `${env.SITE_URL}blog/${slug}#article`,
      headline: article.title,
      description: article.excerpt ?? '',
      datePublished: article.publishedAt ?? undefined,
      url: `${env.SITE_URL}blog/${slug}`,
      ...(imageUrl
        ? { image: { '@type': 'ImageObject', url: imageUrl, width: 1200, height: 630 } }
        : {}),
      author: { '@type': 'Organization', name: 'Projet' },
      publisher: { '@type': 'Organization', name: 'Projet' },
      inLanguage: 'fr-FR',
    },
  ],
};

const articleContent = article.content as PortableTextBlock[] | null | undefined;
---

<PublicLayout
  metadata={metadata}
  breadcrumbs={[
    { name: 'Accueil', url: env.SITE_URL },
    { name: 'Blog', url: `${env.SITE_URL}blog` },
    { name: article.title ?? slug, url: `${env.SITE_URL}blog/${slug}` },
  ]}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <main class="flex min-h-screen w-full flex-col select-none">
    <article class="mx-auto w-full max-w-3xl px-6 pt-20 pb-24 md:pt-28 md:pb-32 lg:px-8">
      {/* Back link */}
      <a
        href="/blog"
        draggable="false"
        class="mb-12 inline-flex items-center gap-2 text-sm text-muted-foreground transition-colors
          duration-200 hover:text-foreground"
      >
        <svg
          width="15"
          height="15"
          viewBox="0 0 15 15"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M6.85355 3.14645C7.04882 3.34171 7.04882 3.65829 6.85355 3.85355L3.70711 7H12.5C12.7761 7 13 7.22386 13 7.5C13 7.77614 12.7761 8 12.5 8H3.70711L6.85355 11.1464C7.04882 11.3417 7.04882 11.6583 6.85355 11.8536C6.65829 12.0488 6.34171 12.0488 6.14645 11.8536L2.14645 7.85355C1.95118 7.65829 1.95118 7.34171 2.14645 7.14645L6.14645 3.14645C6.34171 2.95118 6.65829 2.95118 6.85355 3.14645Z"
            fill="currentColor"
            fill-rule="evenodd"
            clip-rule="evenodd"></path>
        </svg>
        Retour aux articles
      </a>

      {/* Meta */}
      <div class="mb-8 flex flex-col gap-4">
        {
          publishedAt ? (
            <time datetime={article.publishedAt ?? undefined} class="text-sm text-muted-foreground">
              {publishedAt}
            </time>
          ) : null
        }

        <h1
          class="font-heading text-4xl font-semibold tracking-tight text-balance md:text-5xl"
        >
          {article.title}
        </h1>
      </div>

      {/* Hero image */}
      {
        imageUrl ? (
          <div class="mb-12 overflow-hidden rounded-lg">
            <img
              src={imageUrl}
              alt={article.image?.alt || article.title || ''}
              width="1200"
              height="630"
              loading="eager"
              decoding="async"
              draggable="false"
              class="w-full"
            />
          </div>
        ) : null
      }

      {/* Content */}
      <ArticleContent value={articleContent} />
    </article>
  </main>
</PublicLayout>
