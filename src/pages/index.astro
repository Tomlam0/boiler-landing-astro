---
import PublicLayout from '@/layouts/public-layout.astro';
import Hero from '@/features/landing/components/hero';
import { resolveMetadata } from '@/shared/lib/seo/metadata';
import { getDraftModeProps } from '@/sanity/preview/draft-mode';
import { loadQuery } from '@/sanity/content/load-query';
import { HOMEPAGE_QUERY } from '@/sanity/schemas/documents/homepage/homepage.queries';
import type { HOMEPAGE_QUERY_RESULT } from '@/sanity/sanity.types';

export const prerender = true;

const { perspectiveCookie } = getDraftModeProps(Astro.cookies);
const { data } = await loadQuery<HOMEPAGE_QUERY_RESULT>({
  query: HOMEPAGE_QUERY,
  perspectiveCookie,
});

const metadata = await resolveMetadata({
  title: data?.seoTitle ?? 'Projet — Votre marque, sublimée',
  description:
    data?.seoDescription ??
    "Découvrez Projet, un site vitrine élégant et intuitif qui met en valeur votre identité.",
  siteName: 'Projet',
});
---

<PublicLayout metadata={metadata}>
  <main class="mx-auto flex min-h-screen w-full flex-col select-none">
    <Hero client:visible />
  </main>
</PublicLayout>
