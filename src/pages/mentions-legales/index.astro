---
import type { PortableTextBlock } from '@portabletext/types';

import PublicLayout from '@/layouts/public-layout.astro';
import LegalContent from '@/shared/components/portable-text/legal-content.astro';
import { resolveMetadata } from '@/shared/lib/seo/metadata';
import { env } from '@/shared/lib/env';
import { getDraftModeProps } from '@/sanity/lib/draft-mode';
import { loadQuery } from '@/sanity/lib/load-query';
import { LEGAL_QUERY } from '@/sanity/schemas/documents/legal/legal.queries';
import type { LEGAL_QUERY_RESULT } from '@/sanity/sanity.types';

const { perspectiveCookie } = getDraftModeProps(Astro.cookies);
const { data: legal } = await loadQuery<LEGAL_QUERY_RESULT>({
  query: LEGAL_QUERY,
  perspectiveCookie,
});

const metadata = await resolveMetadata({
  title: legal?.seoTitle ?? 'Mentions légales — Projet',
  description:
    legal?.seoDescription ??
    "Politique de confidentialité, conditions générales d'utilisation et politique de cookies.",
  path: 'mentions-legales',
  siteName: 'Projet',
});

const sections = [
  {
    id: 'privacy-policy',
    title: 'Politique de confidentialité',
    content: legal?.privacyPolicy as PortableTextBlock[] | undefined,
  },
  {
    id: 'terms-and-conditions',
    title: "Conditions générales d'utilisation",
    content: legal?.termsAndConditions as PortableTextBlock[] | undefined,
  },
  {
    id: 'cookie-policy',
    title: 'Politique de cookies',
    content: legal?.cookiePolicy as PortableTextBlock[] | undefined,
  },
].filter((section) => section.content && section.content.length > 0);

const lastUpdated = legal?.lastUpdated
  ? new Date(legal.lastUpdated).toLocaleDateString('fr-FR', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;
---

<PublicLayout
  metadata={metadata}
  breadcrumbs={[
    { name: 'Accueil', url: env.SITE_URL },
    { name: 'Mentions légales', url: `${env.SITE_URL}mentions-legales` },
  ]}
>
  <main class="flex min-h-screen flex-col select-text">
    <div class="mx-auto w-full max-w-7xl px-4 py-16">
      <div class="mb-8">
        <a
          href="/"
          draggable="false"
          class="mb-6 inline-flex h-8 items-center gap-2 rounded-md px-3 text-xs font-medium
            transition-colors hover:bg-muted hover:text-foreground"
        >
          <svg
            width="15"
            height="15"
            viewBox="0 0 15 15"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            class="mr-2 h-4 w-4"
          >
            <path
              d="M6.85355 3.14645C7.04882 3.34171 7.04882 3.65829 6.85355 3.85355L3.70711 7H12.5C12.7761 7 13 7.22386 13 7.5C13 7.77614 12.7761 8 12.5 8H3.70711L6.85355 11.1464C7.04882 11.3417 7.04882 11.6583 6.85355 11.8536C6.65829 12.0488 6.34171 12.0488 6.14645 11.8536L2.14645 7.85355C1.95118 7.65829 1.95118 7.34171 2.14645 7.14645L6.14645 3.14645C6.34171 2.95118 6.65829 2.95118 6.85355 3.14645Z"
              fill="currentColor"
              fill-rule="evenodd"
              clip-rule="evenodd"></path>
          </svg>
          Retour
        </a>
        <h1 class="mb-4 text-4xl font-bold text-foreground">Mentions légales</h1>
        {lastUpdated ? <p class="text-muted-foreground">Dernière mise à jour : {lastUpdated}</p> : null}
      </div>

      {
        sections.length === 0 ? (
          <p class="text-muted-foreground">
            Les mentions légales ne sont pas encore renseignées. Merci de configurer le contenu
            dans le Studio Sanity à l'adresse <code>/studio</code>.
          </p>
        ) : (
          <div class="lg:grid lg:grid-cols-4 lg:gap-8">
            <aside class="hidden lg:col-span-1 lg:block lg:min-h-screen">
              <nav class="sticky top-28 space-y-2">
                {sections.map((section, index) => (
                  <a
                    href={`#${section.id}`}
                    draggable="false"
                    class="group flex items-center gap-3 rounded-lg p-3 text-sm transition-colors
                      hover:bg-muted"
                  >
                    <div
                      class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full
                        bg-primary text-xs font-medium text-primary-foreground"
                    >
                      {index + 1}
                    </div>
                    <span
                      class="text-muted-foreground transition-colors group-hover:text-foreground"
                    >
                      {section.title}
                    </span>
                  </a>
                ))}
              </nav>
            </aside>

            <div class="lg:col-span-3">
              <div class="space-y-16">
                {sections.map((section) => (
                  <section id={section.id} class="scroll-mt-24">
                    <div class="mb-6 border-b border-border pb-4">
                      <h2 class="text-3xl font-bold text-foreground">{section.title}</h2>
                    </div>

                    <LegalContent value={section.content} />
                  </section>
                ))}
              </div>
            </div>
          </div>
        )
      }
    </div>
  </main>
</PublicLayout>
