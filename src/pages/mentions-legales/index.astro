---
import PublicLayout from '@/layouts/public-layout.astro';
import { marketingMetadata } from '@/shared/lib/seo/metadata';
import {
  termsAndPrivacySections,
  termsAndPrivacyConfig,
} from '@/features/legal/data/terms-data';

const lastUpdatedFormatted = new Date(termsAndPrivacyConfig.lastUpdated).toLocaleDateString(
  'fr-FR',
  {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  }
);
---

<PublicLayout metadata={marketingMetadata.terms}>
  <div class="flex min-h-screen flex-col">
    <main class="flex-1 px-4 py-16 select-text">
      <div class="mx-auto max-w-7xl">
        <div class="mb-8">
          <a
            href="/"
            draggable="false"
            class="hover:bg-accent hover:text-accent-foreground mb-6 inline-flex h-8 items-center
              gap-2 rounded-md px-3 text-xs font-medium transition-colors"
          >
            <svg
              width="15"
              height="15"
              viewBox="0 0 15 15"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              class="mr-2 h-4 w-4"
            >
              <path
                d="M6.85355 3.14645C7.04882 3.34171 7.04882 3.65829 6.85355 3.85355L3.70711 7H12.5C12.7761 7 13 7.22386 13 7.5C13 7.77614 12.7761 8 12.5 8H3.70711L6.85355 11.1464C7.04882 11.3417 7.04882 11.6583 6.85355 11.8536C6.65829 12.0488 6.34171 12.0488 6.14645 11.8536L2.14645 7.85355C1.95118 7.65829 1.95118 7.34171 2.14645 7.14645L6.14645 3.14645C6.34171 2.95118 6.65829 2.95118 6.85355 3.14645Z"
                fill="currentColor"
                fill-rule="evenodd"
                clip-rule="evenodd"></path>
            </svg>
            Retour
          </a>
          <h1 class="text-foreground mb-4 text-4xl font-bold">Conditions Légales</h1>
          <p class="text-muted-foreground">
            Dernière mise à jour : {lastUpdatedFormatted}
          </p>
        </div>

        <div class="lg:grid lg:grid-cols-4 lg:gap-8">
          {/* Sidebar Navigation - Desktop Only */}
          <aside class="hidden lg:col-span-1 lg:block lg:min-h-screen">
            <nav class="sticky top-24 space-y-2">
              {
                termsAndPrivacySections.map((section, index) => (
                  <a
                    href={`#${section.id}`}
                    draggable="false"
                    class="hover:bg-muted-foreground group flex items-center gap-3 rounded-lg p-3
                      text-sm transition-colors"
                  >
                    <div
                      class="bg-primary text-primary-foreground flex h-6 w-6 shrink-0 items-center
                        justify-center rounded-full text-xs font-medium"
                    >
                      {index + 1}
                    </div>
                    <span class="text-muted-foreground transition-colors group-hover:text-white">
                      {section.title}
                    </span>
                  </a>
                ))
              }
            </nav>
          </aside>

          {/* Main Content */}
          <div class="lg:col-span-3">
            <div class="space-y-16">
              {
                termsAndPrivacySections.map((section) => (
                  <section id={section.id} class="scroll-mt-24">
                    <div class="border-border mb-6 border-b pb-4">
                      <h2 class="text-foreground text-3xl font-bold">{section.title}</h2>
                    </div>

                    <div class="space-y-2">
                      {section.content.map((item) => {
                        if (Array.isArray(item)) {
                          return (
                            <p class="text-muted-foreground text-base leading-relaxed">
                              {item.map((subItem) => {
                                if (typeof subItem === 'string') return subItem;
                                if (subItem.type === 'link') {
                                  return (
                                    <a
                                      href={subItem.url}
                                      target={subItem.target || '_blank'}
                                      rel="noopener noreferrer"
                                      draggable="false"
                                      class="text-primary hover:underline"
                                    >
                                      {subItem.text}
                                    </a>
                                  );
                                }
                                return subItem.text;
                              })}
                            </p>
                          );
                        }

                        if (typeof item === 'string') {
                          if (item === '') return <div class="h-2" />;

                          if (item.startsWith('### ')) {
                            return (
                              <h3 class="text-foreground mt-8 mb-4 text-xl font-semibold first:mt-0">
                                {item.replace('### ', '')}
                              </h3>
                            );
                          }

                          if (
                            item === item.toUpperCase() &&
                            item.length > 10 &&
                            !item.startsWith('•')
                          ) {
                            return (
                              <p class="text-foreground my-4 text-sm font-semibold uppercase">
                                {item}
                              </p>
                            );
                          }

                          if (item.startsWith('• ')) {
                            return (
                              <li class="text-muted-foreground ml-4 flex list-none text-base leading-relaxed">
                                <span class="text-primary mr-2">•</span>
                                <span>{item.substring(2)}</span>
                              </li>
                            );
                          }

                          if (item.endsWith(':') && !item.includes('**')) {
                            return (
                              <p class="text-foreground mt-4 mb-2 text-base leading-relaxed font-medium">
                                {item}
                              </p>
                            );
                          }

                          return (
                            <p class="text-muted-foreground text-base leading-relaxed">{item}</p>
                          );
                        }

                        if (item.type === 'link') {
                          return (
                            <p class="text-muted-foreground text-base leading-relaxed">
                              <a
                                href={item.url}
                                target={item.target || '_blank'}
                                rel="noopener noreferrer"
                                draggable="false"
                                class="text-primary hover:underline"
                              >
                                {item.text}
                              </a>
                            </p>
                          );
                        }

                        return (
                          <p class="text-muted-foreground text-base leading-relaxed">{item.text}</p>
                        );
                      })}
                    </div>
                  </section>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</PublicLayout>
