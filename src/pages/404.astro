---
import BaseLayout from '@/layouts/base-layout.astro';
import Nav from '@/shared/components/layout/nav';
import Footer from '@/shared/components/layout/footer';
import { MotionPreset } from '@/shared/components/services/motion-preset';
import { buttonVariants } from '@/shared/components/ui/button';
import { resolveMetadata } from '@/shared/lib/seo/metadata';

const metadata = resolveMetadata({
  title: 'Page non trouvée — Projet',
  description: "La page que vous cherchez n'existe pas.",
  noIndex: true,
  siteName: 'Projet',
});
---

<BaseLayout metadata={metadata}>
  <div class="flex min-h-screen flex-col select-none">
    <Nav client:load />
    <section class="flex flex-1 flex-col items-center justify-center gap-8 px-6 pt-36 pb-32">
      <MotionPreset client:visible fade delay={0.1} transition={{ duration: 0.6 }}>
        <span class="text-xs font-medium tracking-widest text-muted-foreground uppercase">
          Erreur 404
        </span>
      </MotionPreset>
      <MotionPreset
        client:visible
        slide={{ direction: 'up', offset: 30 }}
        fade
        delay={0.2}
        transition={{ duration: 0.8 }}
      >
        <h1
          class="text-center font-heading text-5xl leading-none font-normal tracking-tight
            text-balance sm:text-7xl"
        >
          Page non <em class="text-accent">trouvée</em>
        </h1>
      </MotionPreset>
      <MotionPreset
        client:visible
        slide={{ direction: 'up', offset: 20 }}
        fade
        delay={0.35}
        transition={{ duration: 0.7 }}
      >
        <p class="max-w-md text-center text-lg leading-relaxed font-light text-muted-foreground">
          La page que vous cherchez n&apos;existe pas ou a été déplacée.
        </p>
      </MotionPreset>
      <MotionPreset
        client:visible
        slide={{ direction: 'up', offset: 15 }}
        fade
        delay={0.5}
        transition={{ duration: 0.6 }}
      >
        <a href="/" draggable="false" class={buttonVariants({ variant: 'default', size: 'lg' })}>
          <svg
            width="15"
            height="15"
            viewBox="0 0 15 15"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            class="mr-1 h-4 w-4"
          >
            <path
              d="M6.85355 3.14645C7.04882 3.34171 7.04882 3.65829 6.85355 3.85355L3.70711 7H12.5C12.7761 7 13 7.22386 13 7.5C13 7.77614 12.7761 8 12.5 8H3.70711L6.85355 11.1464C7.04882 11.3417 7.04882 11.6583 6.85355 11.8536C6.65829 12.0488 6.34171 12.0488 6.14645 11.8536L2.14645 7.85355C1.95118 7.65829 1.95118 7.34171 2.14645 7.14645L6.14645 3.14645C6.34171 2.95118 6.65829 2.95118 6.85355 3.14645Z"
              fill="currentColor"
              fill-rule="evenodd"
              clip-rule="evenodd"></path>
          </svg>
          Retour à l&apos;accueil
        </a>
      </MotionPreset>
    </section>
    <Footer />
  </div>
</BaseLayout>
