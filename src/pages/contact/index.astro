---
import PublicLayout from '@/layouts/public-layout.astro';
import { marketingMetadata } from '@/shared/lib/seo/metadata';
import { env } from '@/shared/lib/env';
---

<PublicLayout
  metadata={marketingMetadata.contact}
  breadcrumbs={[
    { name: 'Accueil', url: env.SITE_URL },
    { name: 'Contact', url: `${env.SITE_URL}contact` },
  ]}
>
  <main class="mx-auto flex min-h-screen w-full flex-col select-none">
    <section class="flex flex-1 flex-col items-center justify-center px-6 pt-36 pb-32">
      <span class="mb-6 text-xs font-medium tracking-widest text-muted-foreground uppercase">
        Contact
      </span>
      <h1
        class="mb-6 text-center font-heading text-5xl leading-none font-normal tracking-tight
          text-balance sm:text-7xl"
      >
        Parlons de votre <em class="text-accent">projet</em>
      </h1>
      <p class="max-w-xl text-center text-lg leading-relaxed font-light text-muted-foreground">
        Cette page est en cours de construction. Revenez bientôt pour nous contacter.
      </p>
    </section>
  </main>
</PublicLayout>
