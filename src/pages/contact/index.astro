---
import PublicLayout from '@/layouts/public-layout.astro';
import { ContactForm } from '@/features/contact/components/contact-form';
import { resolveMetadata } from '@/shared/lib/seo/metadata';
import { env } from '@/shared/lib/env';
import { getDraftModeProps } from '@/sanity/lib/draft-mode';
import { loadQuery } from '@/sanity/lib/load-query';
import { CONTACT_PAGE_QUERY } from '@/sanity/schemas/documents/contact-page/contact-page.queries';
import type { CONTACT_PAGE_QUERY_RESULT } from '@/sanity/sanity.types';

const { perspectiveCookie } = getDraftModeProps(Astro.cookies);
const { data } = await loadQuery<CONTACT_PAGE_QUERY_RESULT>({
  query: CONTACT_PAGE_QUERY,
  perspectiveCookie,
});

const metadata = await resolveMetadata({
  title: data?.seoTitle ?? 'Contact — Projet',
  description: data?.seoDescription ?? 'Contactez-nous — nous vous répondrons dans les plus brefs délais.',
  path: 'contact',
  siteName: 'Projet',
});
---

<PublicLayout
  metadata={metadata}
  breadcrumbs={[
    { name: 'Accueil', url: env.SITE_URL },
    { name: 'Contact', url: `${env.SITE_URL}contact` },
  ]}
>
  <main class="mx-auto flex min-h-screen w-full flex-col select-none">
    <section class="mx-auto w-full max-w-xl px-6 pt-20 pb-24 md:pt-28 md:pb-32">
      <span class="mb-6 block text-xs font-medium tracking-widest text-accent uppercase">
        Contact
      </span>
      <h1
        class="mb-4 font-heading text-4xl font-semibold tracking-tight text-foreground
          md:text-5xl"
      >
        Écrivez-nous
      </h1>
      <p class="mb-12 text-base leading-relaxed text-muted-foreground">
        Remplissez le formulaire ci-dessous et nous vous répondrons dans les plus brefs délais.
      </p>
      <ContactForm client:visible />
    </section>
  </main>
</PublicLayout>
