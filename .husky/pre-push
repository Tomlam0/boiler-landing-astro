#!/bin/sh
protected_branch='main'
current_branch=$(git rev-parse --abbrev-ref HEAD)

if [ "$current_branch" = "$protected_branch" ]; then
    # Check if this is a merge commit (which would be legitimate)
    if git rev-parse --verify MERGE_HEAD >/dev/null 2>&1; then
        echo "Merge commit detected on main branch - allowing push."
        exit 0
    fi

    # Check if the last commit is a merge commit
    if git log -1 --pretty=format:%s | grep -q "^Merge"; then
        echo "Merge commit detected on main branch - allowing push."
        exit 0
    fi

    echo "================================================================"
    echo "ERROR: Direct push to the 'main' branch is forbidden."
    echo "================================================================"
    echo "If you're trying to merge staging into main:"
    echo "1. Make sure you're doing it via a proper merge commit"
    echo "2. Or use a Pull Request on your Git hosting platform"
    echo "----------------------------------------------------------------"
    exit 1
fi

# Run `pnpm dedupe --check` only if dependency files changed in the commits
# being pushed. Catches lockfile drift locally instead of waiting for CI.
remote_branch="origin/$current_branch"
dep_pattern='^(package\.json|pnpm-lock\.yaml|pnpm-workspace\.yaml)$'

if git rev-parse --verify "$remote_branch" >/dev/null 2>&1; then
    changed_files=$(git diff --name-only "$remote_branch"...HEAD)
else
    # New branch with no remote yet — inspect all commits on this branch.
    changed_files=$(git log --name-only --pretty=format: HEAD)
fi

if echo "$changed_files" | grep -qE "$dep_pattern"; then
    echo "📦 Dependency files changed — checking lockfile is deduped..."
    if ! pnpm dedupe --check >/dev/null 2>&1; then
        echo ""
        echo "================================================================"
        echo "ERROR: pnpm-lock.yaml is not deduped."
        echo "================================================================"
        echo "Run the following locally, then re-push:"
        echo ""
        echo "    pnpm dedupe"
        echo "    git add pnpm-lock.yaml"
        echo "    git commit -m '🔧 chore(deps): pnpm dedupe lockfile'"
        echo "----------------------------------------------------------------"
        exit 1
    fi
    echo "✅ Lockfile is deduped"
fi

exit 0
