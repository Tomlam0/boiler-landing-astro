{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": ["src/pages/**/*.{ts,tsx,astro}"],
  "project": [
    "src/pages/**/*.{ts,tsx,astro}",
    "src/layouts/**/*.{ts,tsx,astro}",
    "src/features/**/*.{ts,tsx}",
    "src/shared/**/*.{ts,tsx,astro}"
  ],
  "ignore": ["src/shared/components/ui/**"],
  "ignoreDependencies": [
    "tailwindcss",
    "tw-animate-css",
    "shadcn",
    "tailwind-scrollbar",
    "@commitlint/config-conventional",
    "@commitlint/cz-commitlint",
    "tsx",
    "prettier-plugin-astro"
  ],
  "rules": {
    "enumMembers": "error",
    "exports": "error",
    "files": "error",
    "nsExports": "error",
    "nsTypes": "error",
    "types": "error",
    "duplicates": "error",
    "unlisted": "error"
  }
}
