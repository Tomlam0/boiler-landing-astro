{
  "name": "boiler-landing-astro",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "dev": "concurrently -n astro,sanity -c blue,magenta \"astro dev\" \"sanity dev\"",
    "dev:astro": "astro dev",
    "dev:sanity": "sanity dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "ts": "astro check && tsc --noEmit --pretty",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "cz": "cz",
    "knip": "knip",
    "typegen": "sanity schema extract --enforce-required-fields && sanity typegen generate",
    "deploy:sanity:staging": "STUDIO_TARGET=staging SANITY_DATASET=production sanity deploy --url boiler-landing-astro-staging",
    "deploy:sanity:prod": "STUDIO_TARGET=production SANITY_DATASET=production sanity deploy --url boiler-landing-astro",
    "prepare": "husky"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-emoji-conventional",
      "useGitmojis": true
    }
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.5.0",
    "@astrojs/react": "^5.0.4",
    "@astrojs/sitemap": "^3.7.2",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@fontsource/instrument-serif": "^5.2.8",
    "@portabletext/types": "^4.0.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@sanity/astro": "^3.4.0",
    "@sanity/client": "^7.22.0",
    "@sanity/icons": "^3.7.4",
    "@sanity/image-url": "^2.1.1",
    "@sanity/preview-url-secret": "^4.0.6",
    "@sanity/ui": "^3.2.0",
    "@sanity/vision": "^5.24.0",
    "@sanity/visual-editing": "^5.3.4",
    "@sanity/webhook": "^4.0.4",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.3.1",
    "astro-portabletext": "^0.13.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "groq": "^5.25.0",
    "lucide-react": "^1.14.0",
    "motion": "^12.38.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0",
    "sanity": "^5.24.0",
    "sanity-plugin-media": "^4.2.0",
    "tailwind-merge": "^3.6.0",
    "tailwind-scrollbar": "^4.0.2",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@commitlint/cz-commitlint": "^21.0.0",
    "@commitlint/types": "^21.0.0",
    "@eslint-react/eslint-plugin": "^5.8.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "commitizen": "^4.3.1",
    "commitlint-config-gitmoji": "^2.3.1",
    "concurrently": "^9.2.1",
    "cz-emoji-conventional": "^1.2.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-only-warn": "^1.2.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-tailwind-canonical-classes": "^1.3.3",
    "husky": "^9.1.7",
    "knip": "^6.12.2",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-classnames": "^0.10.1",
    "prettier-plugin-merge": "^0.10.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "shadcn": "^4.7.0",
    "styled-components": "^6.4.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.90.0"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx,astro}": "eslint --fix",
    "./*.{js,ts,mjs}": "eslint --fix"
  }
}
