{
  "plugins": [
    "prettier-plugin-astro",
    "prettier-plugin-tailwindcss",
    "prettier-plugin-classnames",
    "prettier-plugin-merge"
  ],
  "tailwindFunctions": ["cn", "cva", "clsx"],
  "tailwindStylesheet": "./src/styles/globals.css",

  "trailingComma": "es5",

  "printWidth": 100,

  "useTabs": false,
  "tabWidth": 2,

  "singleQuote": true,

  "semi": true,

  "bracketSpacing": true,
  "bracketSameLine": false,

  "endOfLine": "auto",

  "overrides": [
    {
      "files": "*.astro",
      "options": {
        "parser": "astro"
      }
    }
  ]
}
